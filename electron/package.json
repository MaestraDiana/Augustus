{
    "name": "augustus-electron",
    "version": "0.9.2",
    "description": "Augustus - Electron Shell",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "dependencies": {
        "electron-updater": "^6.1.0",
        "electron-log": "^5.1.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.augustus.app",
        "productName": "Augustus",
        "directories": {
            "output": "dist"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "TheFeloniousMonk",
                "repo": "Augustus"
            }
        ],
        "icon": "../icons/augustus-icon-1024.png",
        "win": {
            "target": "nsis",
            "icon": "../icons/augustus-icon-512.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "../icons/augustus-icon-1024.png",
            "category": "public.app-category.developer-tools",
            "minimumSystemVersion": "12.0"
        },
        "linux": {
            "target": "AppImage",
            "icon": "../icons",
            "category": "Development"
        },
        "files": [
            "main.js",
            "preload.js"
        ],
        "extraResources": [
            {
                "from": "../backend/dist/augustus",
                "to": "backend"
            },
            {
                "from": "../frontend/dist",
                "to": "frontend/dist"
            }
        ]
    }
}
