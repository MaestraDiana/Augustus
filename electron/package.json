{
    "name": "augustus-electron",
    "version": "0.2.0",
    "description": "Augustus - Electron Shell",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.0.0"
    },
    "build": {
        "appId": "com.augustus.app",
        "productName": "Augustus",
        "directories": {
            "output": "dist"
        },
        "icon": "../icons/augustus-icon-256.png",
        "win": {
            "target": "nsis",
            "icon": "../icons/augustus-icon-256.png"
        },
        "mac": {
            "target": "dmg",
            "icon": "../icons/augustus-icon-256.png"
        },
        "linux": {
            "icon": "../icons"
        },
        "files": [
            "main.js",
            "preload.js"
        ],
        "extraResources": [
            {
                "from": "../backend",
                "to": "backend"
            },
            {
                "from": "../frontend/dist",
                "to": "frontend/dist"
            }
        ]
    }
}
